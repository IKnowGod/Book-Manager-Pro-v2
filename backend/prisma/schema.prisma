// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Book {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notes     Note[]
  folders   Folder[]
}

model Note {
  id        Int      @id @default(autoincrement())
  bookId    Int
  folderId  Int?     // Optional folder the note belongs to
  type      String   // 'character' | 'chapter' | 'detail'
  title     String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book            Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  folder          Folder?         @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags            TagsOnNotes[]
  inconsistencies Inconsistency[] @relation("NoteInconsistencies")
  chapterInconsistencies Inconsistency[] @relation("ChapterInconsistencies")
  sourceLinks     NoteLink[]      @relation("SourceLinks")
  targetLinks     NoteLink[]      @relation("TargetLinks")
}

model Folder {
  id        Int      @id @default(autoincrement())
  bookId    Int
  name      String
  parentId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  parent    Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("FolderHierarchy")
  notes     Note[]
}

model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique

  notes TagsOnNotes[]
}

// Explicit join table for Note <-> Tag many-to-many
model TagsOnNotes {
  noteId    Int
  tagId     Int
  createdAt DateTime @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

model Inconsistency {
  id           Int      @id @default(autoincrement())
  noteId        Int
  chapterNoteId Int?     // which chapter note contains the offending text
  description   String
  offendingText String
  status        String   @default("active") // 'active' | 'ignored' | 'resolved'
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  note        Note  @relation("NoteInconsistencies", fields: [noteId], references: [id], onDelete: Cascade)
  chapterNote Note? @relation("ChapterInconsistencies", fields: [chapterNoteId], references: [id], onDelete: SetNull)
}

model NoteLink {
  id         Int      @id @default(autoincrement())
  sourceId   Int
  targetId   Int
  linkType   String   @default("related") // 'character_mention' | 'plot_reference' | 'thematic' | 'related'
  status     String   @default("approved") // 'pending' | 'approved' | 'rejected'
  reason     String   @default("")
  createdAt  DateTime @default(now())

  sourceNote Note @relation("SourceLinks", fields: [sourceId], references: [id], onDelete: Cascade)
  targetNote Note @relation("TargetLinks", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
}

model Setting {
  key   String @id
  value String
}
